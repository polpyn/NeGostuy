SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# Docker Compose: PostgreSQL. Локально без Docker тот же .env подхватится, но settings.py
# переключит на SQLite, если DB_HOST=postgres и процесс не в контейнере.
# Для Postgres на localhost: DB_HOST=127.0.0.1 и миграции на свою БД.
# Вне контейнера, но с сетью compose (редко): DB_USE_COMPOSE_NETWORK=1
DB_ENGINE=django.db.backends.postgresql
DB_NAME=negostuy
DB_USER=negostuy
DB_PASSWORD=negostuy
DB_HOST=postgres
DB_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=900

# ============================================================
# AI POSTPROCESS
# ============================================================
# Провайдер LLM: auto | gemini | openrouter | ollama
# auto: приоритет openrouter (если ключ) -> gemini (если ключ) -> ollama.
# auto: при наличии OPENROUTER_API_KEY первым идёт OpenRouter (см. OPENROUTER_MODEL), не Google.
# Только прямой Google Gemini + учёт в AI Studio: AI_PROVIDER=gemini и GEMINI_MODEL=...
AI_PROVIDER=auto
AI_POSTPROCESS_ENABLED=1
AI_POSTPROCESS_HEURISTIC_FALLBACK=1

# Google AI Studio — получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# По умолчанию ниже — полный Flash. Для большего дневного лимита в AI Studio часто выгоднее:
GEMINI_MODEL=gemini-3.1-flash-lite-preview
#GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=120
# HTTP/HTTPS-прокси для запросов в Gemini (если прямого доступа из РФ нет).
# Примеры:
#   GEMINI_PROXY=http://user:pass@host:port
#   GEMINI_PROXY=http://127.0.0.1:8080
# Пусто = без прокси (либо системные HTTP_PROXY/HTTPS_PROXY).
GEMINI_PROXY=
# Повтор при 503/429 (перегрузка API). Иначе первое окно с началом документа может остаться без правок.
GEMINI_MAX_RETRIES=5
GEMINI_RETRY_BACKOFF_SEC=2
GEMINI_RETRY_MAX_WAIT_SEC=60

# OpenRouter (OpenAI-совместимый шлюз, обычно доступен из РФ без VPN).
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_TIMEOUT=120

# Ollama (локальный fallback)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=240

# Окно анализа (в абзацах)
AI_POSTPROCESS_WINDOW_SIZE=50
AI_POSTPROCESS_WINDOW_OVERLAP=5
# Лимит окон за прогон (см. WINDOW_SIZE/OVERLAP). Мало — конец документа не попадёт в Gemini.
AI_POSTPROCESS_MAX_WINDOWS=40
# Пауза между окнами, сек (напр. 6–8 при частых 429 на бесплатном tier). 0 = без паузы.
AI_POSTPROCESS_INTER_WINDOW_SEC=0
# 1 = только фрагменты со списками (дешевле; начало без нумерации может не попасть в LLM). 0 = весь текст.
AI_POSTPROCESS_LIST_ONLY_WINDOWS=0
AI_POSTPROCESS_DEBUG=1
# В debug_ai/*.json: document_head_preview + windows_llm_digest (кратко по каждому окну).
# TRACE=1: полные промпты/ответы в JSON + опционально папка llm_trace_<ts>/wN_prompt.txt и wN_response.txt
#AI_POSTPROCESS_TRACE=1
#AI_POSTPROCESS_TRACE_FILES=1
#AI_POSTPROCESS_TRACE_CONSOLE=1
#AI_POSTPROCESS_TRACE_PROMPT_HEAD=8000
#AI_POSTPROCESS_TRACE_PROMPT_TAIL=4000
#AI_POSTPROCESS_TRACE_RESPONSE_MAX=200000
